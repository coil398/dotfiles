#!/bin/sh
# Global pre-commit dispatcher (managed by dotfiles).
# Activated by `git config --global core.hooksPath ~/.githooks` (set in etc/link.sh).
#
# Responsibilities:
#   1.  Run gitleaks against staged changes (skipped if uninstalled or bypassed).
#   1.5 Run foreign-ssot-guard (dotfiles SSOT contamination check, dotfiles repo only).
#   2.  Dispatch to repo-local hooks (.husky/pre-commit, .githooks/pre-commit)
#       so that per-repo customization (husky, custom hooks) keeps working.
#
# Bypass:
#   - GITLEAKS_DISABLE=1 git commit ...          # skip secret scan only
#   - FOREIGN_GUARD_DISABLE=1 git commit ...     # skip ssot guard only
#   - git commit --no-verify ...                 # skip everything (Git built-in)

set -e

color_warn()  { printf '\033[1;33m%s\033[0m\n' "$*" >&2; }
color_error() { printf '\033[1;31m%s\033[0m\n' "$*" >&2; }

# --- 1. gitleaks ------------------------------------------------------------
if [ "${GITLEAKS_DISABLE:-0}" = "1" ]; then
    color_warn "[pre-commit] GITLEAKS_DISABLE=1 — skipping secret scan."
elif command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --redact --no-banner; then
        color_error "[pre-commit] gitleaks detected potential secrets. Commit aborted."
        color_error "             Inspect the report above, redact, or use GITLEAKS_DISABLE=1 / --no-verify if a false positive."
        exit 1
    fi
else
    color_warn "[pre-commit] gitleaks not installed — skipping secret scan. Install via dotfiles install.sh / brew_install.sh."
fi

# --- 1.5 foreign SSOT guard (dotfiles SSOT contamination check) -------------
# dotfiles リポ配下でのみ発動 (スクリプト側が hook 物理パスで自己判定し、
# dotfiles 以外なら exit 0 で素通り)。FOREIGN_GUARD_DISABLE=1 / --no-verify で bypass。
FOREIGN_SSOT_GUARD="$HOME/.claude/hooks/foreign-ssot-guard.sh"
if [ -x "$FOREIGN_SSOT_GUARD" ]; then
    if ! "$FOREIGN_SSOT_GUARD"; then
        exit 1
    fi
fi

# --- 2. Dispatch to repo-local hooks ----------------------------------------
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[ -z "$REPO_ROOT" ] && exit 0

# Resolve self path to avoid recursion when this dispatcher is itself the
# repo-local .githooks/pre-commit (e.g. inside the dotfiles repo).
SELF="$(cd -P "$(dirname "$0")" 2>/dev/null && pwd)/$(basename "$0")"

for local_hook in \
    "$REPO_ROOT/.husky/pre-commit" \
    "$REPO_ROOT/.githooks/pre-commit"
do
    [ -x "$local_hook" ] || continue
    target="$(cd -P "$(dirname "$local_hook")" 2>/dev/null && pwd)/$(basename "$local_hook")"
    [ "$target" = "$SELF" ] && continue
    "$local_hook" "$@"
done

exit 0
