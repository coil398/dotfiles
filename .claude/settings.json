{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git stash list *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(diff *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(awk *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(command *)",
      "Bash(type *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(ln *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(ps *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(date *)",
      "Bash(uname *)",
      "Bash(id)",
      "Bash(whoami)",
      "Bash(npm show *)",
      "Bash(curl *)",
      "WebSearch",
      "WebFetch",
      "mcp__context7__resolve-library-id",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_wait_for",
      "Edit(*/.claude/projects/*/memory/**)",
      "Write(*/.claude/projects/*/memory/**)",
      "Edit(docs/plans/**)",
      "Write(docs/plans/**)",
      "Edit(docs/brainstorm/**)",
      "Write(docs/brainstorm/**)",
      "Edit(docs/walkthrough/**)",
      "Write(docs/walkthrough/**)",
      "Edit(docs/tester/**)",
      "Write(docs/tester/**)",
      "mcp__serena__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Read(**/node_modules/**)",
      "Read(**/.next/**)",
      "Read(**/.nuxt/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/__pycache__/**)",
      "Read(**/.venv/**)",
      "Read(**/target/**)",
      "Read(**/coverage/**)",
      "Read(**/.turbo/**)",
      "Read(**/.cache/**)",
      "Read(**/*.lock)",
      "Read(**/package-lock.json)",
      "Read(**/yarn.lock)",
      "Read(**/pnpm-lock.yaml)"
    ],
    "additionalDirectories": [
      "~/.claude/projects"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "echo \"$(basename \"$PWD\") | $(git branch --show-current 2>/dev/null) | $(npx -y ccusage statusline 2>/dev/null)\"",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "temperature": 0,
  "toolSettings": {
    "bash": {
      "timeout": 120000,
      "sandboxEnabled": true
    }
  }
}
