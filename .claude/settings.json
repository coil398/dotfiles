{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "temperature": 0,
  "maxTokens": 4096,
  "toolSettings": {
    "bash": {
      "timeout": 120000,
      "sandboxEnabled": true
    },
    "permissions": {
      "requireConfirmation": true,
      "autoApprove": [
        "Read",
        "Grep",
        "Glob"
      ]
    }
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "ccusage statusline"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
