{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "temperature": 0,
  "toolSettings": {
    "bash": {
      "timeout": 120000,
      "sandboxEnabled": true
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git stash list *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(ps *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(npm show *)",
      "WebSearch",
      "WebFetch",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(sudo *)",
      "Bash(su *)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "bash /home/coil398/.claude/statusline-command.sh"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
