# Host-side environment for /home/claw/openclaw/.env on the Claw VPS.
# Copy this to ~/openclaw/.env and fill in the real secret values.
# This file (.env.example) intentionally contains NO secrets.

OPENCLAW_CONFIG_DIR=/home/claw/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/claw/.openclaw/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
# Generate a fresh value, e.g.: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
# Default = ghcr.io/openclaw/openclaw:latest. Use openclaw:local for self-built.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_EXTRA_MOUNTS=
OPENCLAW_HOME_VOLUME=
OPENCLAW_DOCKER_APT_PACKAGES=
OPENCLAW_EXTENSIONS=
OPENCLAW_SANDBOX=
OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock
DOCKER_GID=
OPENCLAW_INSTALL_DOCKER_CLI=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
OPENCLAW_TZ=

# Channel & provider secrets, read by openclaw.json via SecretRef { source:env }.
# Fill in from the respective dashboards (LINE Developers, MiniMax, DeepSeek).
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
